}

body:json {
  {
    "pan": "4111111111111111",
    "expiryMonth": 12,
    "expiryYear": 2027,
    "cardScheme": "VISA",
    "tokenType": "ONE_TIME"
  }
}

assert {
  res.status: eq 400
}
